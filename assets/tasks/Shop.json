{
    "task": [
        {
            "name": "Shop",
            "label": "$task.Shop.label",
            "entry": "ShopMain",
            "description": "$task.Shop.description",
            "option": [
                "CommonShopFreeGoods",
                "CommonShopCoreDustCase",
                "ArenaShopItemList",
                "RecyclingShopList"
            ],
            "group": ["daily"]
        }
    ],
    "option": {
        "CommonShopFreeGoods": {
            "type": "switch",
            "label": "$option.CommonShopFreeGoods.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShopFreeGoodsPurchase": {
                            "enabled": true
                        },
                        "ShopFreeReset": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShopFreeGoodsPurchase": {
                            "enabled": false
                        },
                        "ShopFreeReset": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "CommonShopCoreDustCase": {
            "type": "switch",
            "label": "$option.CommonShopCoreDustCase.label",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShopCoreDustCasePurchase": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShopCoreDustCasePurchase": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "ArenaShopItemList": {
            "type": "checkbox",
            "default_case": [],
            "label": "$option.ArenaShopItemList.label",
            "cases": [
                {
                    "name": "ArenaShopFireCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopFireCodeManual",
                    "pipeline_override": {
                        "ShopFireCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopWaterCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopWaterCodeManual",
                    "pipeline_override": {
                        "ShopWaterCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopWindCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopWindCodeManual",
                    "pipeline_override": {
                        "ShopWindCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopElectricCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopElectricCodeManual",
                    "pipeline_override": {
                        "ShopElectricCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopIronCodeManual",
                    "label": "$option.ArenaShopItemList.ArenaShopIronCodeManual",
                    "pipeline_override": {
                        "ShopIronCodeManualPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ArenaShopCodeManualSelectionBox",
                    "label": "$option.ArenaShopItemList.ArenaShopCodeManualSelectionBox",
                    "pipeline_override": {
                        "ShopCodeManualSelectionBoxPurchase": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "RecyclingShopList": {
            "type": "checkbox",
            "default_case": ["Gem"],
            "label": "$option.RecyclingShopList.label",
            "cases": [
                {
                    "name": "GoodTeamworkBox",
                    "label": "$option.RecyclingShopList.GoodTeamworkBox",
                    "pipeline_override": {
                        "ShopGoodTeamworkBoxPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "MaintenanceKitBox",
                    "label": "$option.RecyclingShopList.MaintenanceKitBox",
                    "pipeline_override": {
                        "ShopMaintenanceKitBoxPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "CuratedManufacturerArms",
                    "label": "$option.RecyclingShopList.CuratedManufacturerArms",
                    "pipeline_override": {
                        "ShopCuratedManufacturerArmsPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Gem",
                    "label": "$option.RecyclingShopList.Gem",
                    "pipeline_override": {
                        "ShopGemPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Voucher",
                    "label": "$option.RecyclingShopList.Voucher",
                    "pipeline_override": {
                        "ShopVoucherPurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "UpgradeMaterials",
                    "label": "$option.RecyclingShopList.UpgradeMaterials",
                    "pipeline_override": {
                        "ShopUpgradeMaterialsPurchase": {
                            "enabled": true
                        }
                    }
                }
            ]
        }
    }
}
