{
    "task": [
        {
            "name": "CashShop",
            "label": "$task.CashShop.label",
            "entry": "CashShopMain",
            "description": "$task.CashShop.description",
            "option": [
                "CashShopFreePackage",
                "StepUpPackage"
            ],
            "group": ["daily"]
        }
    ],
    "option": {
        "CashShopFreePackage": {
            "type": "switch",
            "label": "$option.CashShopFreePackage.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShopChooseOrdinaryPackage": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShopChooseOrdinaryPackage": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "StepUpPackage": {
            "type": "switch",
            "label": "$option.StepUpPackage.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ShopStepUpPackagePurchase": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ShopStepUpPackagePurchase": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
