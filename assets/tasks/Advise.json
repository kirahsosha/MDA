{
    "task": [
        {
            "name": "Advise",
            "label": "$task.Advise.label",
            "entry": "AdviseMain",
            "description": "$task.Advise.description",
            "option": [
                "NikkeAdvise",
                "AdviseEpisodeViewingReward"
            ],
            "group": ["daily"]
        }
    ],
    "option": {
        "NikkeAdvise": {
            "type": "switch",
            "label": "$option.NikkeAdvise.label",
            "description": "$task.NikkeAdvise.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AdviseEnterAdvisePage": {
                            "enabled": true
                        }
                    },
                    "option": ["AdviseEpisodeReward"]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "AdviseEnterAdvisePage": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AdviseEpisodeReward": {
            "type": "switch",
            "label": "$option.AdviseEpisodeReward.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AdviseEpisodeReward": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "AdviseEpisodeReward": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AdviseEpisodeViewingReward": {
            "type": "switch",
            "label": "$option.AdviseEpisodeViewingReward.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AdviseEpisodeViewing": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "AdviseEpisodeViewing": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
