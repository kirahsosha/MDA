{
    "interface_version": 2,
    "name": "MDA",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "contact": "QQ群: 584275905",
    "license": "LICENSE",
    "github": "https://github.com/1204244136/MDA",
    "version": "1.0.0",
    "languages": {
        "zh_cn": "locales/interface/zh_cn.json",
        "en_us": "locales/interface/en_us.json"
    },
    "controller": [
        {
            "name": "Win32-Front",
            "label": "$controller.Win32-Front.label",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "NIKKE",
                "screencap": "ScreenDC",
                "mouse": "Seize",
                "keyboard": "Seize"
            },
            "permission_required": true
        },
        {
            "name": "Win32-Window-Background",
            "label": "$controller.Win32-Window-Background.label",
            "type": "Win32",
            "win32": {
                "class_regex": "UnityWndClass",
                "window_regex": "NIKKE",
                "screencap": "Background",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "PostMessage"
            },
            "permission_required": true
        }
    ],
    "resource": [
        {
            "name": "国际服",
            "path": [
                "./resource"
            ]
        }
    ],
    "task": [],
    "group": [
        {
            "name": "daily",
            "label": "$group.daily.label",
            "description": "$group.daily.description"
        },
        {
            "name": "realtime",
            "label": "$group.realtime.label",
            "description": "$group.realtime.description"
        },
        {
            "name": "utility",
            "label": "$group.utility.label",
            "description": "$group.utility.description"
        }
    ],
    "import": [
        "tasks/CashShop.json",
        "tasks/Shop.json",
        "tasks/SimulationRoom.json",
        "tasks/Arena.json",
        "tasks/TribeTower.json",
        "tasks/Interception.json",
        "tasks/Output.json",
        "tasks/Advise.json",
        "tasks/Cooperation.json",
        "tasks/DailyRewards.json",
        "tasks/preset/DailyFull.json",
        "tasks/preset/QuickDaily.json"
    ]
}
