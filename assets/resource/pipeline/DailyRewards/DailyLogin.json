{
    "DailyRewardsDailyLogin": {
        "desc": "每日登录奖励",
        "max_hit": 1,
        "next": [
            "DailyRewardsDailyLoginEntryFlow",
            "CommonEndTask"
        ]
    },
    "DailyRewardsDailyLoginEntryFlow": {
        "desc": "每日登录奖励入口",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "NavigationArkVisible"
                ]
            }
        },
        "next": [
            "DailyLoginSearch",
            "[JumpBack]CoordinatedOperationsSlideBanner",
            "CommonEndTask"
        ]
    },
    "DailyLoginSearch": {
        "desc": "寻找每日登录奖励图标",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    9,
                    60,
                    151,
                    52
                ],
                "template": [
                    "Common/RedDot.png" //占位，应该去task页面修改
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]DailyLoginRewardsClaim",
            "[JumpBack]CommonConfirmReward",
            "CommonClosePage"
        ]
    },
    "DailyLoginRewardsClaim": {
        "desc": "领取每日登录奖励",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "DailyLoginClaimAllButtonVisible",
                    "DailyLoginRewardsAvailable"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500
    },
    "DailyLoginClaimAllButtonVisible": {
        "desc": "登录奖励领取文本可见",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    686,
                    657,
                    139,
                    34
                ],
                "expected": [
                    ".*全部.*"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500
    },
    "DailyLoginRewardsAvailable": {
        "desc": "登录奖励可用",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "DailyLoginClaimAllButtonVisible",
                "lower": [
                    200,
                    200,
                    200
                ],
                "upper": [
                    255,
                    255,
                    255
                ],
                "count": 100
            }
        }
    }
}
