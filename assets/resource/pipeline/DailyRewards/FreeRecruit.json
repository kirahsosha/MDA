{
    "DailyRewardsFreeRecruitMain": {
        "desc": "免费招募入口",
        "max_hit": 1,
        "next": [
            "DailyRewardsFreeRecruitEntry",
            "[JumpBack]NavigationEnterHall"
        ]
    },
    "DailyRewardsFreeRecruitEntry": {
        "desc": "在大厅寻找免费招募入口",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": ["NavigationArkVisible"]
            }
        },
        "next": [
            "DailyRewardsFreeRecruitStart",
            "CommonEndTask"
        ]
    },
    "DailyRewardsFreeRecruitStart": {
        "desc": "免费招募",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": ["DailyRewardsFreeRecruitVisible"]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 1000,
        "next": [
            "[JumpBack]DailyRewardsFreeRecruit",
            "NavigationEnterHall"
        ]
    },
    "DailyRewardsFreeRecruitAvailable": {
        "desc": "可以免费招募",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": ["DailyRewardsFreeRecruitVisible"]
            }
        }
    },
    "DailyRewardsFreeRecruit": {
        "desc": "处理免费招募可用",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": ["DailyRewardsFreeRecruitAvailable"]
            }
        },
        "next": [
            "DailyRewardsClickFreeRecruit",
            "DailyRewardsFreeRecruitNextRecruitClick"
        ]
    },
    "DailyRewardsClickFreeRecruit": {
        "desc": "点击免费招募",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    480,
                    593,
                    43,
                    14
                ],
                "expected": [".*免费.*"]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]NavigationSkipPlot",
            "DailyRewardsConfirmRecruit",
            "[JumpBack]CommonClickBlank"
        ]
    },
    "DailyRewardsConfirmRecruit": {
        "desc": "招募确认",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    485,
                    633,
                    146,
                    34
                ],
                "expected": ["确认"]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 1000
    },
    "DailyRewardsFreeRecruitVisible": {
        "desc": "免费招募的标识",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    750,
                    665,
                    64,
                    22
                ],
                "template": ["DailyRewards/FreeRecruit/FreeRecruit.png"]
            }
        }
    },
    "DailyRewardsFreeRecruitNextRecruitClick": {
        "desc": "下一个招募",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1232,
                    349,
                    46,
                    54
                ],
                "template": ["DailyRewards/FreeRecruit/NextRecruit.png"]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 1000
    }
}
