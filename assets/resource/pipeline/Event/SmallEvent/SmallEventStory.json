{
    "SmallEventStory": {
        "desc": "小活动剧情",
        "enabled": false,
        "max_hit": 1,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    314,
                    413,
                    661,
                    294
                ],
                "expected": [".*加成.*"]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    0,
                    -50,
                    0,
                    0
                ]
            }
        },
        "post_wait_freezes": 500,
        "timeout": 60000,
        "next": ["SmallEventEventStagePageFlow"]
    },
    "SmallEventEventStagePageEntered": {
        "desc": "已进入小活动活动关卡页面",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    5,
                    18,
                    50,
                    16
                ],
                "expected": [".*活动关.*"]
            }
        }
    },
    "SmallEventEventStagePageFlow": {
        "desc": "小活动活动关卡页面流程",
        "max_hit": 2,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": ["SmallEventEventStagePageEntered"]
            }
        },
        "post_wait_freezes": {
            "time": 500,
            "target": [
                494,
                505,
                294,
                131
            ]
        },
        "next": ["SmallEventEventStageBattleFlow"]
    },
    "SmallEventEventStageBattleFlow": {
        "desc": "小活动活动关卡页面战斗流程",
        "next": [
            "SmallEventEventStageBattlePage",
