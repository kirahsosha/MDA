{
    "CashShopMain": {
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "RuntimeQuotaCheck"
            }
        },
        "next": [
            "HallEnterCashShop",
            "[JumpBack]NavigationEnterHall"
        ]
    },
    "HallEnterCashShop": {
        "desc": "进入付费商店",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    358,
                    441,
                    59,
                    21
                ],
                "expected": ["付费商店"]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "CashShopCornerFlow",
            "HallEnterCashShop"
        ]
    },
    "CashShopMainPageEntered": {
        "desc": "处于付费商店",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    15,
                    70,
                    25
                ],
                "expected": ["付费商店"]
            }
        }
    },
    "CashShopCornerFlow": {
        "desc": "付费商店流程",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": ["CashShopMainPageEntered"]
            }
        },
        "next": [
            "[JumpBack]ShopStepUpPackagePurchase",
            "ShopChooseOrdinaryPackage"
        ]
    },
    "ShopStepUpPackagePurchase": {
        "desc": "购买StepUp礼包",
        "max_hit": 1,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    783,
                    389,
                    49,
                    28
                ],
                "expected": ["免费"]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": ["CommonConfirmReward"]
    },
    "ShopChooseOrdinaryPackage": {
        "desc": "选择普通礼包",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1,
                    138,
                    543,
                    44
                ],
                "template": ["CashShop/OrdinaryPackage.png"],
                "threshold": [0.9]
            }
        },
        "pre_wait_freezes": 500,
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]CashShopClickRedDot",
            "[JumpBack]CommonConfirmReward",
            "CommonEndTask"
        ]
    },
    "CashShopClickRedDot": {
        "desc": "点击付费商店红点",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    9,
                    187,
                    509,
                    91
                ],
                "template": ["Common/RedDot.png"],
                "order_by": "Vertical",
                "index": -1
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 200
    }
}
